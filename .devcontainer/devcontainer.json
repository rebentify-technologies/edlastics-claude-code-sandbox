{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "-p",
    "3000:3000",
    "-p",
    "3001:3001",
    "-p",
    "3002:3002",
    "--env-file=${localWorkspaceFolder}/.env"
  ],
  "forwardPorts": [3000, 3001, 3002],
  "portsAttributes": {
    "3000": {
      "label": "scheduling-ui (Vite)"
    },
    "3001": {
      "label": "elastic-pass-ui (Vite)"
    },
    "3002": {
      "label": "helm (Vite)"
    }
  },
  "initializeCommand": [
    "node",
    "-e",
    "const fs=require('fs');if(!fs.existsSync('.env'))fs.copyFileSync('.env.example','.env');for(const d of['.claude-sandbox/config','.claude-sandbox/bash-history'])fs.mkdirSync(d,{recursive:true});"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=${localWorkspaceFolder}/.claude-sandbox/bash-history,target=/commandhistory,type=bind,consistency=delegated",
    "source=${localWorkspaceFolder}/.claude-sandbox/config,target=/home/node/.claude,type=bind,consistency=delegated"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}
