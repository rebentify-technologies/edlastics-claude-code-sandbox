.DS_Store
.env

# Claude Code CLI + shell history from devcontainer bind mounts (sessions, credentials)
/.claude-sandbox/

# Claude Code runtime artifacts that surface in the workspace root
/.claude/scheduled_tasks.lock
/*.jsonl

# Local IDE settings
/.vscode/

# Team canonical clones and developer IDE checkouts — populated by /clone-repos
/dev-agent/
/dev-local/

# Sandbox repo's own ephemeral worktrees for PR work
/worktrees/

# pnpm content-addressable store (shared across all repos in the container)
/.pnpm-store/
